PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/hbr_ranking
JWT_SECRET=your_very_secret_key_here_change_this
NODE_ENV=development

# Cloudinary (https://cloudinary.com で取得)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 管理者設定 (初回起動時に管理者アカウントを自動作成)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# 内部メンバー登録（2段階認証）
# URLトークン: /register.html?ref=INTERNAL_REF_CODE でアクセスした場合のみPW欄が表示される
# コミュニティPW: 表示されたPW欄に入力した値が INTERNAL_PASSWORD と一致した場合に is_internal=true になる
# → 両方一致しないと内部フラグは付与されない
INTERNAL_REF_CODE=your_secret_url_token
INTERNAL_PASSWORD=your_community_password
